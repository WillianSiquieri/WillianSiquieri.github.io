# Copie para .env (uso local) ou configure como GitHub Secrets (uso no CI).

# --- IA de roteiro (obrigatório para roteiros de verdade; sem ele usa mock) ---
ANTHROPIC_API_KEY=

# --- Voz / TTS (opcional; sem ele o vídeo sai com trilha silenciosa) ---
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# Alternativa open-source: aponte para um modelo Piper local
# PIPER_MODEL=pt_BR-faber-medium.onnx

# --- YouTube (obrigatório para publicar/medir; sem ele fica só em fila local) ---
YT_CLIENT_ID=
YT_CLIENT_SECRET=
YT_REFRESH_TOKEN=
# YT_REDIRECT_URI=http://localhost:8787/oauth2callback
