# Copie para .env (uso local) ou configure como GitHub Secrets (uso no CI).
# A pilha padrão é 100% GRATUITA: Gemini (free tier) + edge-tts (sem chave).

# --- IA de roteiro (defina UMA; prioridade no 'auto': Groq > Gemini > Claude) ---
# Groq free tier (recomendado, grátis e confiável): https://console.groq.com/keys
GROQ_API_KEY=
# Gemini free tier (grátis, mas a quota depende da conta/região): https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Alternativa paga (opcional): Claude
ANTHROPIC_API_KEY=

# --- Voz / TTS ---
# Padrão: edge-tts (vozes neurais da Microsoft, grátis, SEM chave) — nada a configurar.
# Opcional (pago, voz premium): ElevenLabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# Opcional (offline, grátis): modelo Piper local
# PIPER_MODEL=pt_BR-faber-medium.onnx

# --- YouTube (obrigatório para publicar/medir; sem ele fica só em fila local) ---
YT_CLIENT_ID=
YT_CLIENT_SECRET=
YT_REFRESH_TOKEN=
# YT_REDIRECT_URI=http://localhost:8787/oauth2callback
