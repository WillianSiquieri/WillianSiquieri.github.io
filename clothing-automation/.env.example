# ---------- IA (legenda do post) — escolha UMA chave (todas free tier, exceto Claude) ----------
# Prioridade no modo automático: Groq -> Gemini -> Claude -> mock
GROQ_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# ---------- WhatsApp (entrada das fotos) ----------
# Provedor de leitura das mensagens recebidas. Veja o README para os formatos.
#   inbox  -> lê um endpoint HTTP (JSON) que acumula as mensagens recebidas
#   mock   -> gera itens fake para testar o pipeline sem WhatsApp
WHATSAPP_PROVIDER=mock
# URL do "inbox" (endpoint que devolve as mensagens recebidas em JSON).
WHATSAPP_INBOX_URL=
# Token opcional enviado como Bearer para o inbox.
WHATSAPP_INBOX_TOKEN=

# ---------- Instagram (saída dos posts) — Instagram Graph API (conta Business/Creator) ----------
# ID da conta do Instagram (Instagram Business Account ID) e token de longa duração.
IG_USER_ID=
IG_ACCESS_TOKEN=
